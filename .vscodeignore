# Source files (TypeScript will be bundled)
src/**
**/*.ts
**/*.map

# Build artifacts (keep only bundled output)
out/
node_modules/
dist/artifacts.json
dist/checksums.txt
dist/config.yaml
dist/metadata.json
dist/*.zip

# Development files
.vscode/**
.vscode-test/**
.gitignore
.yarnrc
.editorconfig
.github/**
.idea/**
.pre-commit-config.yaml
.goreleaser.yaml
.release-please-manifest.json
release-please-config.json
testdata/

# Documentation (except README)
CLAUDE.md
examples/
docs/

# Configuration files
tsconfig.json
tsconfig.build.json
webpack.config.js
eslint.config.mjs
.eslintrc*
.prettierrc*
package-lock.json
.claude/

# Scripts and tools
scripts/

# Test files
test/
tests/
**/*.test.ts
**/*.test.js

# Logs and temporary files
*.log
*.tmp
*.bak

# Package files
*.vsix

# OS generated files
.DS_Store
Thumbs.db